import random

def start_game():
    
    number = random.randint(1, 3) 
    
    input("Ask a yes or no question: ")

    if number == 1:
        print("Yes")
    elif number == 2:
        print("50/50")
    else:
        print("No")
    
    again = input("Would you like to ask again? (yes/no): ")
    
    if again.lower() == "yes":
        start_game() 
    else:
        print("Thank you for consulting with the 8 Ball")

start_game()
